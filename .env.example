# Variables d'environnement — Kolori RH
# Copiez ce fichier en .env et remplissez vos propres valeurs Supabase

# Clés Supabase (récupérez-les sur https://supabase.com > Votre projet > Settings > API)
SUPABASE_URL="https://VOTRE_PROJECT_ID.supabase.co"
SUPABASE_PUBLISHABLE_KEY="votre_anon_public_key"

VITE_SUPABASE_URL="https://VOTRE_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="votre_anon_public_key"
VITE_SUPABASE_PROJECT_ID="votre_project_id"
